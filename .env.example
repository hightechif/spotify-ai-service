# Spotify API Developer Credentials
# Get these from the Spotify Developer Dashboard (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Spotify Refresh Token
# Run the helper script `get_token.py` to generate this token
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token_here

# LLM Engine Configuration
# Model to run locally via Ollama
OLLAMA_MODEL=qwen2.5:3b

# Optional path overrides for Spotify MCP Server
# By default, the service resolves adjacent directories dynamically.
# Uncomment and configure these if your directory structure differs.
# SPOTIFY_MCP_SERVER_DIR=/path/to/spotify-mcp-server
# SPOTIFY_MCP_PYTHON_PATH=/path/to/spotify-mcp-server/.venv/bin/python

# Optional configuration ports
SPOTIFY_REDIRECT_PORT=8888
